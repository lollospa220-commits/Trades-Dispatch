# ── Supabase PostgreSQL ──────────────────────────────────────────────────────
# Dashboard Supabase → Project Settings → Database → Connection string
#
# DATABASE_URL = Transaction pooler (porta 6543) — usata dall'app su Vercel
# DIRECT_URL   = Direct connection (porta 5432) — usata da Prisma migrate
#
# Esempio (sostituisci [PASSWORD], [PROJECT_REF] e [REGION] — trova regione in Connect):
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
#
# Nota: db.[PROJECT_REF].supabase.co:5432 (direct) spesso non funziona da IPv4.
# Usa sempre il pooler da Dashboard → Connect.

DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# JWT session cookie — genera una stringa random lunga (min 32 caratteri)
AUTH_SECRET="change-me-to-a-long-random-string"

# ── Vercel (opzionale) ───────────────────────────────────────────────────────
# Imposta le stesse variabili in Vercel → Project → Settings → Environment Variables

# ── Notifiche cliente (fase 2) ─────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+39...
# RESEND_API_KEY=