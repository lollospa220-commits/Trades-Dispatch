// Opifice — schema relazionale multi-tenant (un Company = un abbonato SaaS).
// Ogni record operativo (technician, customer, job) è scoped su companyId.
// Database: Supabase PostgreSQL (locale e produzione).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum JobStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

enum AccountType {
  COMPANY
  SOLO
}

enum SubscriptionPlan {
  SOLO
  TEAM
  PRO
}

model Company {
  id                   String           @id @default(cuid())
  name                 String
  slug                 String           @unique
  email                String           @unique
  passwordHash         String           @map("password_hash")
  accountType          AccountType      @default(COMPANY) @map("account_type")
  plan                 SubscriptionPlan @default(SOLO)
  stripeCustomerId     String?          @map("stripe_customer_id")
  stripeSubscriptionId String?          @map("stripe_subscription_id")
  subscriptionStatus   String           @default("trialing") @map("subscription_status")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  technicians          Technician[]
  customers            Customer[]
  jobs                 Job[]
  jobReports           JobReport[]
  passwordResetTokens  PasswordResetToken[]
  billingProfile       CompanyProfile?
  invoices             Invoice[]

  @@map("companies")
}

// Dati fiscali dell'azienda emittente — intestazione delle fatture.
model CompanyProfile {
  id           String   @id @default(cuid())
  companyId    String   @unique @map("company_id")
  businessName String?  @map("business_name")
  vatNumber    String?  @map("vat_number")
  taxCode      String?  @map("tax_code")
  address      String?
  pec          String?
  sdiCode      String?  @map("sdi_code")
  iban         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_profiles")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  companyId String   @map("company_id")
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String?
  success   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, createdAt])
  @@map("login_attempts")
}

model Technician {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  active    Boolean  @default(true)
  companyId String   @map("company_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobs    Job[]

  @@index([companyId])
  @@map("technicians")
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  vatNumber String?  @map("vat_number")
  taxCode   String?  @map("tax_code")
  sdiCode   String?  @map("sdi_code")
  pec       String?
  companyId String   @map("company_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobs     Job[]
  invoices Invoice[]

  @@index([companyId])
  @@map("customers")
}

model Job {
  id           String    @id @default(cuid())
  title        String
  description  String?
  status       JobStatus @default(SCHEDULED)
  scheduledAt  DateTime  @map("scheduled_at")
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  companyId    String    @map("company_id")
  customerId   String    @map("customer_id")
  technicianId String?   @map("technician_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  technician Technician? @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  report     JobReport?
  invoices   Invoice[]

  @@index([companyId, scheduledAt])
  @@index([technicianId])
  @@map("jobs")
}

// Fattura interna (PDF + tracciamento, nessun invio SDI in v1).
// Importi in centesimi di euro: niente float, serializzazione pulita verso i client component.
model Invoice {
  id            String        @id @default(cuid())
  companyId     String        @map("company_id")
  customerId    String        @map("customer_id")
  jobId         String?       @map("job_id")
  year          Int
  number        Int
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime      @map("issue_date")
  notes         String?
  subtotalCents Int           @map("subtotal_cents")
  vatCents      Int           @map("vat_cents")
  totalCents    Int           @map("total_cents")
  sentAt        DateTime?     @map("sent_at")
  paidAt        DateTime?     @map("paid_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  company  Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  job      Job?          @relation(fields: [jobId], references: [id], onDelete: SetNull)
  lines    InvoiceLine[]

  @@unique([companyId, year, number])
  @@index([companyId, status])
  @@index([companyId, issueDate])
  @@map("invoices")
}

model InvoiceLine {
  id             String  @id @default(cuid())
  invoiceId      String  @map("invoice_id")
  description    String
  quantity       Decimal @db.Decimal(10, 2)
  unitPriceCents Int     @map("unit_price_cents")
  vatRate        Int     @map("vat_rate") // 22 | 10 | 4 | 0
  totalCents     Int     @map("total_cents") // imponibile riga già arrotondato
  position       Int     @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_lines")
}

model JobReport {
  id            String   @id @default(cuid())
  jobId         String   @unique @map("job_id")
  companyId     String   @map("company_id")
  workNotes     String?  @map("work_notes")
  signatureData String?  @map("signature_data") @db.Text
  signedByName  String?  @map("signed_by_name")
  photoData     String?  @map("photo_data") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  job     Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("job_reports")
}